generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String
  photoBase64    String   @db.Text
  photoTeeth     String?  @db.Text
  photoSide      String?  @db.Text
  quoteShown     String   @default("")
  smileScore     Int?
  analysisJson   String?  @db.Text
  status         LeadStatus @default(PENDING)
  doctorNotes String?  @db.Text
  reviewedAt  DateTime?
  reviewedBy  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model Doctor {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

enum LeadStatus {
  PENDING
  REVIEWED
  PDF_SENT
}
